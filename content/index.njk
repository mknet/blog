---js
const eleventyNavigation = {
	key: "Home",
	order: 1
};

const numberOfLatestPostsToShow = 3;
---
{% set postsCount = collections.posts | length %}
{% set latestPostsCount = postsCount | min(numberOfLatestPostsToShow) %}

<header class="post-hero">
	<p class="post-kicker">Blog</p>
	<h1 class="post-title">{% if latestPostsCount == 1 %}Neuester Beitrag{% else %}Neueste Beiträge{% endif %}</h1>
	<p class="home-lead">Die letzten {{ latestPostsCount }} {% if latestPostsCount == 1 %}Veröffentlichung{% else %}Veröffentlichungen{% endif %}.</p>
</header>

<div class="post-content">
	{% set postslist = collections.posts | head(-1 * numberOfLatestPostsToShow) %}
	{% set postslistCounter = postsCount %}
	{% include "postslist.njk" %}

	{% set morePosts = postsCount - numberOfLatestPostsToShow %}
	{% if morePosts > 0 %}
	<p class="home-archive-teaser">{{ morePosts }} weitere{% if morePosts == 1 %}r Beitrag{% else %} Beiträge{% endif %} im <a href="/blog/">Archiv</a>.</p>
	{% endif %}
</div>

