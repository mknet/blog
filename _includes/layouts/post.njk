---
layout: layouts/base.njk
---
{# Only include the syntax highlighter CSS on blog posts, included with the CSS per-page bundle #}
<style>{% include "node_modules/prismjs/themes/prism-okaidia.css" %}</style>
<style>{% include "css/prism-diff.css" %}</style>
{%- set postTags = tags | filterTagList -%}
{%- set categoryLabel = category or (postTags | first) -%}
{%- set tocItems = content | tocFromContent -%}
{# Voller Seitenpfad + Fragment: funktioniert mit pathPrefix / HtmlBase und bricht nicht auf # allein #}
{%- set tocPageUrl = page.url | url -%}

<div class="post-layout">
	<article class="post-article">
		{%- if tocItems.length %}
		<section class="mobile-toc" aria-label="Inhaltsübersicht">
			<details class="toc" id="toc">
				<summary class="toc-summary">
					<span class="toc-marker" aria-hidden="true"></span>
					<span class="toc-label">Inhaltsübersicht</span>
				</summary>
				<nav class="toc-body" aria-label="Inhaltsübersicht Links">
					<ol class="toc-list">
						{%- for item in tocItems %}
						<li class="toc-item toc-{{ item.level }}"><a href="{{ tocPageUrl }}#{{ item.id }}">{{ item.text | e }}</a></li>
						{%- endfor %}
					</ol>
				</nav>
			</details>
		</section>
		{%- endif %}

		<header class="post-hero">
			{%- if categoryLabel -%}
			<p class="post-kicker">{{ categoryLabel }}</p>
			{%- endif -%}

			<h1 class="post-title">{{ title }}</h1>

			<ul class="post-metadata">
				<li><time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time></li>
			</ul>
		</header>

		<div class="post-content">
			{{ content | safe }}
		</div>

		{%- if postTags.length %}
		<footer class="post-tags" aria-label="Schlagwörter">
			<ul class="post-metadata post-tags-list">
				{%- for tag in postTags %}
				{%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
				<li><a href="{{ tagUrl }}" class="tag-pill">{{ tag }}</a></li>
				{%- endfor %}
			</ul>
		</footer>
		{%- endif %}

{%- if collections.posts %}
{%- set previousPost = collections.posts | getPreviousCollectionItem %}
{%- set nextPost = collections.posts | getNextCollectionItem %}
{%- if nextPost or previousPost %}
<ul class="links-nextprev">
	{%- if previousPost %}<li class="links-nextprev-prev">← Previous<br> <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a></li>{% endif %}
	{%- if nextPost %}<li class="links-nextprev-next">Next →<br><a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a></li>{% endif %}
</ul>
{%- endif %}
{%- endif %}

	</article>

	<aside class="post-sidebar" aria-label="Sidebar">
		{%- if tocItems.length %}
		<nav class="sidebar-block sidebar-headings" aria-label="Inhaltsübersicht">
			{%- for item in tocItems %}
			{%- if item.level == "h2" %}
			<p class="sidebar-title"><a class="sidebar-link" href="{{ tocPageUrl }}#{{ item.id }}">{{ item.text | e }}</a></p>
			{%- else %}
			<p class="sidebar-subtitle"><a class="sidebar-link sidebar-sublink" href="{{ tocPageUrl }}#{{ item.id }}">{{ item.text | e }}</a></p>
			{%- endif %}
			{%- endfor %}
		</nav>
		{%- endif %}

		<div class="sidebar-block author-card">
			<p class="author-name">{{ metadata.author.name }}</p>
			{%- if metadata.author.title -%}
			<p class="author-title">{{ metadata.author.title }}</p>
			{%- endif -%}
			{%- if metadata.author.roles and metadata.author.roles.length -%}
			<ul class="author-roles">
				{%- for role in metadata.author.roles -%}
				<li>{{ role }}</li>
				{%- endfor -%}
			</ul>
			{%- endif -%}
			{%- if metadata.author.phone -%}
			<p class="author-phone">{{ metadata.author.phone }}</p>
			{%- endif -%}

			{%- if metadata.author.imageUrl -%}
			<img class="author-image" src="{{ metadata.author.imageUrl | url }}" alt="" width="874" height="823" loading="lazy" decoding="async" eleventy:ignore>
			{%- else -%}
			<div class="author-image-placeholder" aria-hidden="true"></div>
			{%- endif -%}
		</div>
	</aside>
</div>

{%- if tocItems.length %}
<script>
	(() => {
		const toc = document.getElementById("toc");
		if (!toc) return;
		const open =
			new URLSearchParams(window.location.search).get("toc") === "open" ||
			window.location.hash === "#toc";
		if (open) toc.setAttribute("open", "");
	})();
</script>
{%- endif %}
